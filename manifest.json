{
  "manifest_version": 3,
  "name": "Momentum Dashboard",
  "version": "1.0.0",
  "description": "Personal browser dashboard for focus, weather, crypto, and daily use",

  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },

  "action": {
    "default_icon": "icon.png",
    "default_title": "Momentum Dashboard"
  },

  "permissions": ["geolocation"],

  "host_permissions": [
    "https://apis.scrimba.com/*",
    "https://api.coingecko.com/*",
    "https://api.openweathermap.org/*"
  ],

  "chrome_url_overrides": {
    "newtab": "index.html"
  }
}